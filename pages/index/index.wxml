<view class="container">
  <!-- ===== 固定头部 ===== -->
  <view class="header-fixed">
  <!-- 换购模式提示 -->
  <view wx:if="{{exchangeMode}}" class="exchange-banner">
    <view class="exb-info">
      <text class="exb-icon">↻</text>
      <text class="exb-text">正在选择换货商品，挑选后请点击底部"完成换购选择"</text>
    </view>
    <view class="exb-cancel" bindtap="onCancelExchange">取消</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索产品名称..."
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <text wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 全部 / 买过 -->
  <view class="purchase-filter">
    <view class="pf-tab {{purchaseFilter === 'all' ? 'active' : ''}}" bindtap="onPurchaseFilter" data-filter="all">全部</view>
    <view class="pf-tab {{purchaseFilter === 'bought' ? 'active' : ''}}" bindtap="onPurchaseFilter" data-filter="bought">买过</view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-bar" scroll-x enable-flex>
    <view
      class="category-item {{activeCategory === item ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      wx:for-item="item"
      data-category="{{item}}"
      bindtap="onCategoryTap"
    >{{item}}</view>
  </scroll-view>

  <!-- 搜索结果提示 -->
  <view wx:if="{{keyword}}" class="search-info">搜索"{{keyword}}"，找到 {{products.length}} 个产品</view>
  </view>
  <!-- ===== /固定头部 ===== -->

  <!-- ===== 可滚动列表 ===== -->
  <scroll-view class="scroll-list" scroll-y scroll-top="{{listScrollTop}}" bindscroll="onListScroll">
  <!-- 产品列表 -->
  <view wx:if="{{loading}}" class="loading-hint">加载中...</view>

  <view wx:elif="{{products.length === 0}}" class="empty-state">
    <text wx:if="{{keyword}}">未找到匹配产品</text>
    <text wx:else>暂无产品</text>
  </view>

  <view wx:else class="product-list">
    <view class="product-card card {{item.status === 'out' ? 'product-out' : ''}}" wx:for="{{products}}" wx:key="_id">
      <image class="product-image {{item.status === 'out' ? 'img-out' : ''}}" src="{{item.image || '/images/placeholder.png'}}" mode="aspectFill" catchtap="onPreviewImage" data-url="{{item.image}}" />
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-meta">{{item.category}} / {{item.unit}}</view>
        <view class="product-bottom">
          <view class="price"><text class="price-symbol">¥</text>{{item.priceText}}</view>
          <view wx:if="{{item.status === 'out'}}" class="add-cart-btn add-cart-out">缺货</view>
          <view wx:else class="add-cart-btn" data-product="{{item}}" catchtap="showQtyInput">+</view>
        </view>
      </view>
    </view>
  </view>
  </scroll-view>

  <!-- 数量输入弹窗 -->
  <view wx:if="{{showQtyModal}}" class="modal-mask" catchtouchmove="preventMove">
    <view class="qty-modal">
      <view class="qty-modal-title">输入数量</view>
      <view class="qty-modal-product">{{qtyProduct.name}}</view>
      <view class="qty-modal-price">¥{{qtyProduct.priceText}} / {{qtyProduct.unit}}</view>
      <view class="qty-input-row">
        <view class="qty-minus" bindtap="onQtyMinus">−</view>
        <input
          class="qty-input"
          type="number"
          value="{{qtyValue}}"
          bindinput="onQtyInput"
          focus="{{qtyInputFocus}}"
        />
        <view class="qty-plus" bindtap="onQtyPlus">+</view>
      </view>
      <view class="qty-modal-btns">
        <view class="btn-outline qty-cancel" bindtap="onCancelQty">取消</view>
        <view class="btn-primary qty-confirm" bindtap="onConfirmQty">加入购物车</view>
      </view>
    </view>
  </view>

  <!-- 换购模式：底部完成按钮 -->
  <view wx:if="{{exchangeMode}}" class="exchange-float-bar">
    <view class="efb-btn" catchtap="onCartCheckout">完成换购选择 →</view>
  </view>

  <!-- 图片预览弹窗（自定义，避免 wx.previewImage 导致页面跳到顶部） -->
  <view wx:if="{{showImagePreview}}" class="image-preview-mask" catchtap="onCloseImagePreview">
    <view class="ip-close" catchtap="onCloseImagePreview">✕</view>
    <view wx:if="{{previewImageIndex > 0}}" class="ip-arrow ip-arrow-left" catchtap="onPrevImage">‹</view>
    <image class="ip-image" src="{{previewImageUrl}}" mode="aspectFit" catchtap="" />
    <view wx:if="{{previewImageIndex < previewImageUrls.length - 1}}" class="ip-arrow ip-arrow-right" catchtap="onNextImage">›</view>
    <view wx:if="{{previewImageUrls.length > 1}}" class="ip-indicator">{{previewImageIndex + 1}} / {{previewImageUrls.length}}</view>
  </view>
</view>
