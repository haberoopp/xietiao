.select-all-bar { display: flex; padding: 16rpx 0; }
.check-all { display: flex; align-items: center; gap: 8rpx; font-size: 28rpx; color: #1A1A1A; }

.checkbox {
  width: 40rpx; height: 40rpx;
  border: 3rpx solid #ccc; border-radius: 50%;
  box-sizing: border-box;
}
.checkbox.checked { background: var(--color-primary); border-color: var(--color-primary); }

.cart-item {
  display: flex; align-items: center;
  background: #fff; border-radius: 8rpx;
  padding: 16rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.check-btn { margin-right: 16rpx; }
.item-image { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #E8E8E8; flex-shrink: 0; }
.item-right { flex: 1; margin-left: 16rpx; overflow: hidden; }
.item-name { font-size: 28rpx; font-weight: 500; margin-bottom: 4rpx; }
.item-unit { font-size: 22rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; }
.item-bottom .price { font-size: 28rpx; }

.qty-control { display: flex; align-items: center; gap: 8rpx; }
.qty-btn {
  width: 88rpx; height: 88rpx; line-height: 88rpx;
  text-align: center; background: #F0F0F0; border-radius: 6rpx;
  font-size: 28rpx; color: #1A1A1A;
}
.qty-input {
  width: 80rpx; height: 48rpx;
  border: 1rpx solid #E0E0E0; border-radius: 6rpx;
  text-align: center; font-size: 26rpx;
}

.delete-btn {
  width: 56rpx; height: 56rpx; line-height: 56rpx;
  text-align: center; font-size: 32rpx; color: #ccc;
  flex-shrink: 0; margin-left: 8rpx;
}

.checkout-bar {
  position: fixed; bottom: calc(100rpx + env(safe-area-inset-bottom)); left: 0; right: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx; background: #fff; border-top: 1rpx solid #EEEEEE;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.12);
}
.total-text { font-size: 32rpx; }
.total-text .price { font-size: 36rpx; }
.checkout-btn { padding: 14rpx 48rpx; border-radius: 36rpx; font-size: 28rpx; }

.go-shopping { margin-top: 16rpx; color: var(--color-primary); font-size: 28rpx; }
