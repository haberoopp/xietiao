.go-shopping {
  margin-top: 20rpx;
  color: #d32f2f;
  font-size: 28rpx;
}

.select-all-bar {
  padding: 16rpx 0;
}

.check-all {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #ccc;
  border-radius: 50%;
  margin-right: 16rpx;
  display: inline-block;
  box-sizing: border-box;
}

.checkbox.checked {
  background: #d32f2f;
  border-color: #d32f2f;
}

.cart-item {
  display: flex;
  align-items: center;
  position: relative;
  padding: 16rpx;
}

.check-btn {
  margin-right: 16rpx;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}

.item-right {
  flex: 1;
  margin-left: 16rpx;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
}

.item-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #f0f0f0;
  border-radius: 4rpx;
  font-size: 32rpx;
}

.qty-num {
  margin: 0 16rpx;
  font-size: 28rpx;
  min-width: 40rpx;
  text-align: center;
}

.qty-input {
  width: 80rpx;
  height: 48rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 4rpx;
  text-align: center;
  font-size: 26rpx;
  margin: 0 8rpx;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 28rpx;
  color: #ccc;
  padding: 8rpx;
}

.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.total-text {
  font-size: 30rpx;
}

.checkout-btn {
  padding: 16rpx 50rpx;
  font-size: 28rpx;
}
