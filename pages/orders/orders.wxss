.go-shopping {
  margin-top: 16rpx;
  color: var(--color-primary);
  font-size: 28rpx;
}

.order-card {
  padding: 16rpx;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 16rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-badges {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

/* 退换货标签 */
.badge-return-pending { background: #E67E22; }
.badge-return-approved { background: #1976D2; }
.badge-return-rejected { background: #9E9E9E; }
.badge-return-completed { background: #27AE60; }

.return-reason {
  font-size: 24rpx;
  color: #e65100;
  background: #fff3e0;
  padding: 10rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
}

.rr-title {
  font-weight: 500;
  margin-bottom: 4rpx;
}

.rr-item {
  padding: 2rpx 0;
  font-size: 22rpx;
  color: #bf360c;
}

.rr-exchange {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #1976d2;
}

.rr-reason {
  margin-top: 6rpx;
  padding-top: 6rpx;
  border-top: 1rpx solid #ffe0b2;
  color: #999;
}

.order-products {
  background: #fafafa;
  border-radius: 6rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
}

.op-item {
  display: flex;
  justify-content: space-between;
  padding: 4rpx 0;
  font-size: 26rpx;
}

.op-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.op-qty {
  color: #666;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.order-customer {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.order-address {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.order-delivery {
  font-size: 24rpx;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

/* 订单图片 */
.order-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.oi-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.order-total {
  font-size: 30rpx;
}

.footer-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.copy-btn {
  font-size: 22rpx;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.copy-btn:active {
  background: #fff5f5;
}

.cancel-btn {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  border: 1rpx solid #CCC;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.cancel-btn:active {
  background: #f5f5f5;
}

.return-btn {
  font-size: 22rpx;
  color: #E67E22;
  border: 1rpx solid #E67E22;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.return-btn:active {
  background: #fff8e1;
}

.rebuy-btn {
  font-size: 22rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.rebuy-btn:active {
  background: var(--color-primary-dark);
}

.edit-order-btn {
  font-size: 22rpx;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.edit-order-btn:active {
  background: #fff5f5;
}

/* 对账单导出栏 */
.bill-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx 32rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 16rpx;
}

.bill-info {
  display: flex;
  flex-direction: column;
}

.bill-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.bill-summary {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.bill-export-btn {
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.bottom-links {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 32rpx 0;
}

.bottom-link {
  font-size: 24rpx;
  color: #CCC;
  padding: 8rpx;
}

.bottom-link:active {
  color: var(--color-primary);
}

.admin-link {
  color: #DDD;
}

/* 退换货弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  padding: 30rpx;
  padding-bottom: 130rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-cancel { flex: 1; }
.modal-save { flex: 1; }

/* 退/换类型选择 */
.return-type-select {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  border: 3rpx solid #e0e0e0;
  border-radius: 12rpx;
}

.type-option.active {
  border-color: var(--color-primary);
  background: #fff5f5;
}

.type-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 26rpx;
  color: #333;
}

.type-option.active .type-label {
  color: var(--color-primary);
  font-weight: 600;
}

/* 退换商品选择 */
.return-items-section {
  max-height: 400rpx;
  overflow-y: auto;
  margin-bottom: 20rpx;
}

.return-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.ri-check {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #ccc;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
  box-sizing: border-box;
}

.ri-check.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.ri-info {
  flex: 1;
  overflow: hidden;
}

.ri-name {
  font-size: 26rpx;
}

.ri-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.ri-qty-ctrl {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.qty-btn-sm {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 24rpx;
  color: #1A1A1A;
  background: #F0F0F0;
  border-radius: 6rpx;
}

.qty-input-sm {
  width: 60rpx;
  height: 40rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 6rpx;
  text-align: center;
  font-size: 24rpx;
}

.ri-empty {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
}

/* 换购商品 */
.ex-shop-btn {
  width: 100%;
  margin-top: 8rpx;
  border: 2rpx dashed var(--color-primary);
  color: var(--color-primary);
  font-size: 28rpx;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 8rpx;
  background: #FDF2F2;
}

.ex-shop-btn:active {
  background: #ffebee;
}

.exchange-items {
  background: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.ex-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.ex-item:last-child {
  border-bottom: none;
}

.ex-item-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 6rpx;
  background: #eee;
  flex-shrink: 0;
}

.ex-item-info {
  flex: 1;
  margin-left: 12rpx;
  overflow: hidden;
}

.ex-item-name {
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ex-item-price {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.ex-item-subtotal {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.ex-summary {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #e0e0e0;
}

.ex-summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
  padding: 4rpx 0;
}

.ex-amount.minus {
  color: #27AE60;
}

.ex-amount.plus {
  color: var(--color-primary);
}

.ex-diff {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #e0e0e0;
}

.ex-diff-amount {
  color: #E67E22;
}
