.admin-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.back-btn {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
}

/* 搜索 */
.search-bar {
  padding: 0 0 16rpx;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 16rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}
.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
  flex-shrink: 0;
}

.top-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.add-btn {
  font-size: 26rpx;
  color: #fff;
  background: #d32f2f;
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
}

.import-btn {
  font-size: 26rpx;
  color: #2196f3;
  padding: 10rpx 24rpx;
  border: 1rpx solid #2196f3;
  border-radius: 6rpx;
}

.import-btn:active {
  background: #e3f2fd;
}

.pa-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
}

.pa-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}

.pa-info {
  flex: 1;
  margin-left: 16rpx;
  overflow: hidden;
}

.pa-name {
  font-size: 28rpx;
  font-weight: 500;
}

.pa-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.pa-stock {
  font-size: 22rpx;
  color: #2196f3;
  margin-top: 4rpx;
}

.pa-actions {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  text-align: center;
  margin: 4rpx 0;
}

.action-btn.edit {
  color: #2196f3;
  border: 1rpx solid #2196f3;
}

.action-btn.delete {
  color: #f44336;
  border: 1rpx solid #f44336;
}

/* 表单弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 85vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.form-scroll {
  max-height: 60vh;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.picker-val {
  height: 80rpx;
  line-height: 80rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-row .half {
  flex: 1;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.preview-image {
  width: 200rpx;
  height: 200rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-cancel {
  flex: 1;
}

.modal-save {
  flex: 1;
}
