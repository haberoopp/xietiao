/* ===== scroll-view 布局 ===== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  padding: 0 16rpx;
}
.header-fixed {
  flex-shrink: 0;
}
.scroll-list {
  flex: 1;
  overflow: hidden;
}

.admin-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.back-btn {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
}

/* 搜索 */
.search-bar {
  padding: 0 0 16rpx;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F6FA;
  border-radius: 8rpx;
  padding: 0 16rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}
.search-clear {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 10rpx;
  flex-shrink: 0;
}

.top-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.add-btn {
  font-size: 26rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
}

.import-btn {
  font-size: 26rpx;
  color: #2196f3;
  padding: 10rpx 24rpx;
  border: 1rpx solid #2196f3;
  border-radius: 6rpx;
}

.import-btn:active {
  background: #e3f2fd;
}

.pa-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
}

.pa-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}

.pa-info {
  flex: 1;
  margin-left: 16rpx;
  overflow: hidden;
}

.pa-name {
  font-size: 28rpx;
  font-weight: 500;
}

.pa-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.pa-status-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-suf { background: #27AE60; }
.dot-low { background: #E67E22; }
.dot-out { background: #f44336; }

.status-dot-inline {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  vertical-align: middle;
  margin-right: 10rpx;
}

.pa-status-text {
  font-size: 22rpx;
  color: #666;
}

.pa-recent-sales {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-left: auto;
}

.pa-actions {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  text-align: center;
  margin: 4rpx 0;
}

.action-btn.edit {
  color: #2196f3;
  border: 1rpx solid #2196f3;
}

.action-btn.delete {
  color: #f44336;
  border: 1rpx solid #f44336;
}

/* 表单弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 85vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.form-scroll {
  max-height: 60vh;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.picker-val {
  display: flex;
  align-items: center;
  height: 80rpx;
  line-height: 80rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-row .half {
  flex: 1;
}

.image-upload {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.preview-image {
  width: 200rpx;
  height: 200rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-cancel {
  flex: 1;
}

.modal-save {
  flex: 1;
}

/* ===== 批量管理 ===== */
.batch-btn {
  font-size: 26rpx;
  color: #E67E22;
  padding: 10rpx 24rpx;
  border: 1rpx solid #E67E22;
  border-radius: 6rpx;
}

.batch-btn:active {
  background: #fff3e0;
}

.batch-btn.batch-active {
  color: #fff;
  background: #E67E22;
}

/* 批量操作栏 */
.batch-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.batch-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.batch-bar-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.select-count {
  font-size: 24rpx;
  color: #7F8C8D;
}

/* 选择框 */
.select-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.select-checkbox.checked {
  background: #E67E22;
  border-color: #E67E22;
}

.pa-select-check {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.pa-item.pa-selected {
  border: 2rpx solid #E67E22;
  background: #fff8f0;
}

.batch-delete-btn {
  font-size: 24rpx;
  color: #f44336;
  border: 1rpx solid #f44336;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
}

.batch-delete-btn:active {
  background: #ffebee;
}

.batch-edit-btn {
  font-size: 24rpx;
  color: #fff;
  background: #E67E22;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
}

.batch-edit-btn:active {
  background: #d84315;
}

/* 批量编辑弹窗提示 */
.batch-form-hint {
  font-size: 22rpx;
  color: #7F8C8D;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

/* ===== 图片预览弹窗 ===== */
.image-preview-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.95); z-index: 3000;
  display: flex; align-items: center; justify-content: center;
}
.ip-close {
  position: fixed; top: 60rpx; right: 32rpx; z-index: 3002;
  width: 64rpx; height: 64rpx; line-height: 64rpx; text-align: center;
  font-size: 34rpx; color: #fff; background: rgba(255,255,255,0.2); border-radius: 50%;
}
.ip-image {
  width: 100%; height: 80vh;
}
.ip-arrow {
  position: fixed; top: 50%; transform: translateY(-50%); z-index: 3001;
  width: 72rpx; height: 72rpx; line-height: 72rpx; text-align: center;
  font-size: 48rpx; color: #fff; background: rgba(255,255,255,0.15); border-radius: 50%;
}
.ip-arrow-left { left: 24rpx; }
.ip-arrow-right { right: 24rpx; }
.ip-indicator {
  position: fixed; bottom: 60rpx; left: 50%; transform: translateX(-50%); z-index: 3001;
  font-size: 26rpx; color: #ccc; background: rgba(0,0,0,0.5);
  padding: 8rpx 24rpx; border-radius: 20rpx;
}
