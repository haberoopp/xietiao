<view class="container">
  <!-- 操作栏 -->
  <view class="admin-top-bar">
    <view class="back-btn" bindtap="onBackToOrders">← 返回订单</view>
    <view class="top-actions">
      <view class="import-btn" bindtap="onImport">导入Excel</view>
      <view class="add-btn" bindtap="onAdd">+ 添加产品</view>
      <view class="batch-btn {{selectMode ? 'batch-active' : ''}}" bindtap="onToggleBatchMode">{{selectMode ? '退出批量' : '批量管理'}}</view>
    </view>
  </view>

  <!-- 搜索 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索产品名称或分类..." value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search" />
      <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 批量操作栏 -->
  <view wx:if="{{selectMode}}" class="batch-bar">
    <view class="batch-bar-left">
      <view class="select-all-btn" bindtap="onToggleSelectAll">
        <view class="select-checkbox {{allSelected ? 'checked' : ''}}">{{allSelected ? '✓' : ''}}</view>
        <text>{{allSelected ? '取消全选' : '全选'}}</text>
      </view>
      <text class="select-count">已选 {{selectedCount}} 项</text>
    </view>
    <view class="batch-bar-right">
      <view class="batch-delete-btn" bindtap="onBatchDelete">批量删除</view>
      <view class="batch-edit-btn" bindtap="onBatchEdit">批量编辑</view>
    </view>
  </view>

  <!-- 产品列表 -->
  <view wx:if="{{filteredProducts.length === 0}}" class="empty-state">
    <text>暂无产品，点击上方添加</text>
  </view>

  <view wx:else class="product-admin-list">
    <view class="pa-item card {{selectMode && item.selected ? 'pa-selected' : ''}}" wx:for="{{filteredProducts}}" wx:key="_id">
      <!-- 选择框 -->
      <view wx:if="{{selectMode}}" class="pa-select-check" data-id="{{item._id}}" catchtap="onToggleSelect">
        <view class="select-checkbox {{item.selected ? 'checked' : ''}}">{{item.selected ? '✓' : ''}}</view>
      </view>
      <image class="pa-image" src="{{item.image || '/images/placeholder.png'}}" mode="aspectFill" />
      <view class="pa-info">
        <view class="pa-name">{{item.name}}</view>
        <view class="pa-meta">{{item.category}} / {{item.unit}} / ¥{{item.priceText}}</view>
        <view class="pa-status-row">
          <view class="status-dot {{item.status === 'out' ? 'dot-out' : item.status === 'low' ? 'dot-low' : 'dot-suf'}}"></view>
          <text class="pa-status-text">{{item.status === 'out' ? '缺货' : item.status === 'low' ? '紧张' : '充足'}}</text>
          <text wx:if="{{item.recent_sales}}" class="pa-recent-sales">近7天销量 ¥{{item.recent_sales / 100}}</text>
        </view>
      </view>
      <view wx:if="{{!selectMode}}" class="pa-actions">
        <view class="action-btn edit" data-product="{{item}}" bindtap="onEdit">编辑</view>
        <view class="action-btn delete" data-product="{{item}}" bindtap="onDelete">删除</view>
      </view>
    </view>
  </view>

  <!-- 添加/编辑表单弹窗 -->
  <view wx:if="{{showForm}}" class="modal-mask">
    <view class="modal-content" catchtap="">
      <view class="modal-title">{{editingProduct ? '编辑产品' : '添加产品'}}</view>

      <scroll-view class="form-scroll" scroll-y>
        <view class="form-group">
          <view class="form-label">产品名称 *</view>
          <input class="form-input" placeholder="请输入产品名称" value="{{form.name}}" data-field="name" bindinput="onFormInput" />
        </view>

        <view class="form-group">
          <view class="form-label">分类</view>
          <picker mode="selector" range="{{categories}}" value="0" bindchange="onCategoryChange">
            <view class="picker-val">{{form.category}}</view>
          </picker>
        </view>

        <view class="form-row">
          <view class="form-group half">
            <view class="form-label">单价（元）*</view>
            <input class="form-input" type="digit" placeholder="0.00" value="{{form.price}}" data-field="price" bindinput="onFormInput" />
          </view>
          <view class="form-group half">
            <view class="form-label">单位</view>
            <picker mode="selector" range="{{['米','卷','个','公斤','包']}}" bindchange="onUnitChange">
              <view class="picker-val">{{form.unit}}</view>
            </picker>
          </view>
        </view>

        <view class="form-group">
          <view class="form-label">缺货状态</view>
          <picker mode="selector" range="{{['充足','紧张','缺货']}}" bindchange="onStatusChange">
            <view class="picker-val">
              <view class="status-dot-inline {{form.status === 'out' ? 'dot-out' : form.status === 'low' ? 'dot-low' : 'dot-suf'}}"></view>
              {{form.status === 'out' ? '缺货' : form.status === 'low' ? '紧张' : '充足'}}
            </view>
          </picker>
        </view>

        <view class="form-group">
          <view class="form-label">描述</view>
          <textarea class="form-textarea" placeholder="产品描述（选填）" value="{{form.description}}" data-field="description" bindinput="onFormInput" />
        </view>

        <view class="form-group">
          <view class="form-label">产品图片</view>
          <view class="image-upload" bindtap="onChooseImage">
            <image wx:if="{{form.image}}" class="preview-image" src="{{form.image}}" mode="aspectFill" />
            <view wx:else class="upload-placeholder">+ 选择图片</view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-btns">
        <view class="btn-outline modal-cancel" bindtap="onCancel">取消</view>
        <view class="btn-primary modal-save" bindtap="onSave">保存</view>
      </view>
    </view>
  </view>

  <!-- 批量编辑弹窗 -->
  <view wx:if="{{showBatchForm}}" class="modal-mask">
    <view class="modal-content" catchtap="">
      <view class="modal-title">批量编辑 {{selectedCount}} 个产品</view>

      <scroll-view class="form-scroll" scroll-y>
        <view class="form-group">
          <view class="form-label">分类（留空不修改）</view>
          <picker mode="selector" range="{{batchCategories}}" bindchange="onBatchCategoryChange">
            <view class="picker-val">{{batchForm.category || '点击选择'}}</view>
          </picker>
        </view>

        <view class="form-group">
          <view class="form-label">单位（留空不修改）</view>
          <picker mode="selector" range="{{batchUnits}}" bindchange="onBatchUnitChange">
            <view class="picker-val">{{batchForm.unit || '点击选择'}}</view>
          </picker>
        </view>

        <view class="form-group">
          <view class="form-label">缺货状态（留空不修改）</view>
          <picker mode="selector" range="{{batchStatuses}}" bindchange="onBatchStatusChange">
            <view class="picker-val">
              <view wx:if="{{batchForm.status}}" class="status-dot-inline {{batchForm.status === 'out' ? 'dot-out' : batchForm.status === 'low' ? 'dot-low' : 'dot-suf'}}"></view>
              {{batchForm.status === 'out' ? '缺货' : batchForm.status === 'low' ? '紧张' : batchForm.status === 'sufficient' ? '充足' : '点击选择'}}
            </view>
          </picker>
        </view>

        <view class="batch-form-hint">提示：仅修改选中的字段，留空字段保持不变。不会修改产品名称、价格和图片。</view>
      </scroll-view>

      <view class="modal-btns">
        <view class="btn-outline modal-cancel" bindtap="onCancelBatchForm">取消</view>
        <view class="btn-primary modal-save" bindtap="onSaveBatchEdit">应用到{{selectedCount}}个产品</view>
      </view>
    </view>
  </view>
</view>
