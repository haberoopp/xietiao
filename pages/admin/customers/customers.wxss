.admin-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.back-btn {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
}

/* 搜索 */
.search-bar {
  padding: 0 0 16rpx;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 16rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}
.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
  flex-shrink: 0;
}

.add-btn {
  font-size: 26rpx;
  color: #fff;
  background: #d32f2f;
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
}

.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 客户卡片 */
.customer-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.cust-info {
  flex: 1;
  overflow: hidden;
}

.cust-name {
  font-size: 30rpx;
  font-weight: 500;
}

.cust-phone {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.cust-discount {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.discount-badge {
  font-size: 22rpx;
  color: #fff;
  background: #d32f2f;
  padding: 4rpx 14rpx;
  border-radius: 4rpx;
}

.cust-stats {
  font-size: 22rpx;
  color: #999;
}

.cust-actions {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  text-align: center;
  margin: 4rpx 0;
}

.action-btn.edit {
  color: #2196f3;
  border: 1rpx solid #2196f3;
}

.action-btn.delete {
  color: #f44336;
  border: 1rpx solid #f44336;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 85vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.discount-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-cancel { flex: 1; }
.modal-save { flex: 1; }
.cust-debt {
  font-size: 24rpx;
  color: #f44336;
  font-weight: 500;
  margin-left: 16rpx;
}
