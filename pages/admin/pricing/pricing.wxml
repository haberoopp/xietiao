<view class="container">
  <!-- 顶部栏 -->
  <view class="admin-top-bar">
    <view class="back-btn" bindtap="onBack">← 返回订单</view>
    <view class="next-btn {{selectedCount === 0 ? 'next-disabled' : ''}}" bindtap="onNext">下一步 →</view>
  </view>

  <!-- 搜索（首页风格：圆角白底+阴影） -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">⌕</text>
      <input class="search-input" placeholder="搜索客户名称或手机号..." value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search" />
      <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <view wx:if="{{filteredCustomers.length === 0}}" class="empty-state">
    <text>暂无客户</text>
  </view>

  <view wx:else class="customer-list">
    <view
      class="customer-card card {{selectedPhones[item.phone] ? 'card-selected' : ''}}"
      wx:for="{{filteredCustomers}}"
      wx:key="phone"
      data-phone="{{item.phone}}"
      bindtap="onToggleCustomer"
    >
      <view class="cust-select">
        <view class="select-checkbox {{selectedPhones[item.phone] ? 'checked' : ''}}">
          {{selectedPhones[item.phone] ? '✓' : ''}}
        </view>
      </view>
      <view class="cust-info">
        <view class="cust-name">{{item.name}}</view>
        <view class="cust-phone">{{item.phone}}</view>
        <view class="cust-stats">
          <text wx:if="{{item.totalOrders > 0}}">累计{{item.totalOrders}}单 ¥{{item.amountText}}</text>
          <text wx:if="{{item.debtText}}" class="cust-debt">欠款 ¥{{item.debtText}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
