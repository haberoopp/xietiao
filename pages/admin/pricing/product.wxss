.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

.header-fixed {
  flex-shrink: 0;
  padding: 0 24rpx;
}

.admin-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 0 16rpx;
}

.back-btn {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
}

.save-btn {
  font-size: 26rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
}

/* 已选客户横滑标签 */
.selected-customers {
  display: flex;
  align-items: center;
  padding: 0 0 16rpx;
}

.sc-label {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.sc-scroll {
  flex: 1;
  white-space: nowrap;
}

.sc-tags {
  display: flex;
  gap: 12rpx;
}

.sc-tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: #FFF5F5;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  flex-shrink: 0;
}

/* 首页风格搜索框 */
.search-bar {
  padding: 0 0 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 12rpx 20rpx;
  box-shadow: var(--shadow-card);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  color: #999;
}

.search-input {
  flex: 1;
  height: 56rpx;
  font-size: 28rpx;
}

.search-clear {
  font-size: 24rpx;
  color: #ccc;
  padding: 8rpx;
  margin-left: 8rpx;
}

/* 批量操作栏 */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.batch-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.select-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  background: #fff;
}

.select-checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.select-count {
  font-size: 24rpx;
  color: #999;
}

.batch-bar-right {
  display: flex;
  align-items: center;
}

.batch-edit-btn {
  padding: 10rpx 20rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 产品列表 */
.scroll-list {
  flex: 1;
  overflow: hidden;
}

.pricing-list {
  padding: 0 24rpx 40rpx;
}

.pricing-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  margin-bottom: 8rpx;
}

.pricing-item.pricing-selected {
  background: #FFF5F5;
}

.pricing-select {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.pricing-info {
  flex: 1;
  min-width: 0;
}

.pricing-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pricing-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.pricing-input-wrap {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.pricing-unit {
  font-size: 28rpx;
  color: var(--color-primary);
  margin-right: 4rpx;
}

.pricing-input {
  width: 130rpx;
  height: 60rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.pricing-input.input-has-price {
  border-color: #4CAF50;
  background: #f1f8e9;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 85vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.batch-form-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 16rpx 0;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-cancel { flex: 1; }
.modal-save { flex: 1; }

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
