.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

.admin-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx 16rpx;
}

.back-btn {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
}

.next-btn {
  font-size: 26rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
}

.next-disabled {
  background: #ccc;
  color: #999;
}

/* 首页风格搜索框：圆角白底+阴影 */
.search-bar {
  padding: 0 24rpx 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 12rpx 20rpx;
  box-shadow: var(--shadow-card);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  color: #999;
}

.search-input {
  flex: 1;
  height: 56rpx;
  font-size: 28rpx;
}

.search-clear {
  font-size: 24rpx;
  color: #ccc;
  padding: 8rpx;
  margin-left: 8rpx;
}

/* 客户列表 */
.customer-list {
  flex: 1;
  overflow-y: auto;
  padding: 0 24rpx 24rpx;
}

.customer-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.customer-card.card-selected {
  background: #FFF5F5;
  border: 2rpx solid var(--color-primary);
}

.cust-select {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.select-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  background: #fff;
}

.select-checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.cust-info {
  flex: 1;
  overflow: hidden;
}

.cust-name {
  font-size: 30rpx;
  font-weight: 500;
}

.cust-phone {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.cust-stats {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cust-debt {
  color: #f44336;
  font-weight: 500;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
