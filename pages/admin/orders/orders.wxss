.admin-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.top-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.role-badge {
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 4rpx;
}

.role-badge.role-manager { background: var(--color-primary); }
.role-badge.role-delivery { background: #2196f3; }
.role-badge.role-warehouse { background: #27AE60; }

.logout-link {
  font-size: 22rpx;
  color: #7F8C8D;
}

.logout-link:active {
  color: var(--color-primary);
}

.top-actions {
  display: flex;
  gap: 12rpx;
}

.go-dash-btn {
  font-size: 26rpx;
  color: #E67E22;
  padding: 10rpx 24rpx;
  border: 1rpx solid #E67E22;
  border-radius: 6rpx;
}

.go-products-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: 6rpx;
}

.status-tabs {
  white-space: nowrap;
  padding: 10rpx 0;
  margin-bottom: 10rpx;
}

.tab-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  background: #fff;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #666;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
}

/* 搜索框 */
.search-bar {
  padding: 0 0 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F6FA;
  border-radius: 8rpx;
  padding: 0 16rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #7F8C8D;
  padding: 10rpx;
  flex-shrink: 0;
}

.order-customer-info {
  background: #fafafa;
  border-radius: 6rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
}

.info-row {
  font-size: 26rpx;
  padding: 4rpx 0;
}

/* 已拿货/未拿货 badge */
.badge-pickedup-yes { background: #27AE60; }
.badge-pickedup-no { background: #7F8C8D; }

/* 已拿货/未拿货 底部按钮 */
.pickedup-btn {
  font-size: 24rpx;
  color: #666;
  background: #F5F6FA;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
}

.pickedup-btn.pu-done {
  color: #fff;
  background: #27AE60;
}

.pickedup-btn:active {
  opacity: 0.8;
}

.info-label {
  color: #7F8C8D;
}

.info-phone {
  color: #2196f3;
}

.info-row-addr {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.info-addr-text {
  flex: 1;
  overflow: hidden;
}

.addr-value {
  word-break: break-all;
}

.navi-btn {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 6rpx 16rpx;
  background: #27AE60;
  color: #fff;
  font-size: 22rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

.navi-btn:active {
  background: #388e3c;
}

.order-products {
  margin-bottom: 8rpx;
}

.op-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.op-text {
  flex: 1;
  overflow: hidden;
}

.op-mark-low {
  font-size: 20rpx;
  color: #E67E22;
  border: 1rpx solid #E67E22;
  border-radius: 4rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.op-mark-low:active {
  background: #fff3e0;
}

.op-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.op-detail {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #666;
}

.order-remark {
  font-size: 24rpx;
  color: #7F8C8D;
  margin-bottom: 12rpx;
  padding: 8rpx;
  background: #fff8e1;
  border-radius: 4rpx;
}

.rr-title {
  font-weight: 500;
  color: #e65100;
  margin-bottom: 4rpx;
}

.rr-badge {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.rr-list {
  margin-bottom: 4rpx;
}

.rr-item {
  font-size: 22rpx;
  color: #bf360c;
  padding: 2rpx 0;
}

.rr-exchange {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #1976d2;
}

.rr-reason {
  margin-top: 6rpx;
  padding-top: 6rpx;
  border-top: 1rpx solid #ffe0b2;
  color: #7F8C8D;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 12rpx;
}

.footer-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: nowrap;
  flex-shrink: 0;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.order-total {
  font-size: 30rpx;
}

.edit-price-btn {
  font-size: 22rpx;
  color: #E67E22;
  border: 1rpx solid #E67E22;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  line-height: 1;
}

.edit-price-btn:active {
  background: #fff8e1;
}

.order-card {
  position: relative;
}

.copy-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  z-index: 1;
}

.copy-btn:active {
  background: #fff5f5;
}

.status-btn {
  font-size: 22rpx;
  color: #fff;
  background: #2196f3;
  padding: 8rpx 14rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  line-height: 1;
}

.status-btn:active {
  background: #1976d2;
}

.pickedup-btn {
  font-size: 22rpx;
  padding: 8rpx 14rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  line-height: 1;
}

.payment-toggle-btn {
  font-size: 22rpx;
  padding: 8rpx 14rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  line-height: 1;
}

/* 订单头部标签 */
.header-badges {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 退换货状态标签 */
.badge-return-pending { background: #E67E22; }
.badge-return-approved { background: #2196f3; }
.badge-return-rejected { background: #7F8C8D; }
.badge-return-completed { background: #27AE60; }

/* 退换货处理按钮 */
.return-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 16rpx;
}

.return-act {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 6rpx;
  color: #fff;
}

.return-act.approve {
  background: #27AE60;
}

.return-act.reject {
  background: #f44336;
}

.return-act.complete {
  background: #2196f3;
}

.return-act:active {
  opacity: 0.8;
}

/* 订单图片 */
.order-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.oi-image-item {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.oi-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}

.oi-img-del {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 24rpx;
  color: #fff;
  background: rgba(0,0,0,0.6);
  border-radius: 50%;
}

/* 上传按钮 */
.upload-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.upload-btn {
  font-size: 24rpx;
  color: #27AE60;
  border: 1rpx solid #27AE60;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
}

.upload-btn:active {
  background: #e8f5e9;
}

.upload-hint {
  font-size: 22rpx;
  color: #E67E22;
  margin-left: 12rpx;
}

/* 改价弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.price-modal {
  background: #fff;
  border-radius: 20rpx;
  width: 600rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.price-current {
  font-size: 28rpx;
  color: #7F8C8D;
  margin-bottom: 24rpx;
  text-align: center;
}

.price-input {
  width: 100%;
  height: 90rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: 8rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-primary);
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-cancel { flex: 1; }
.modal-save { flex: 1; }

.badge-payment-paid {
  background: #e8f5e9;
  color: #2e7d32;
}

.badge-payment-unpaid {
  background: #fff3e0;
  color: #e65100;
}

.payment-toggle-btn {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 6rpx;
}

.pt-unpaid {
  color: #E67E22;
  border: 1rpx solid #E67E22;
}

.pt-unpaid:active {
  background: #fff3e0;
}

.pt-paid {
  color: #2e7d32;
  background: #e8f5e9;
  border: 1rpx solid #a5d6a7;
}

/* Ensure action buttons have consistent touch targets */
.admin-order-card { padding: 16rpx; background: #fff; border-radius: 8rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); margin-bottom: 16rpx; }
.action-btn { min-height: 56rpx; line-height: 40rpx; padding: 8rpx 16rpx; border-radius: 6rpx; font-size: 24rpx; }

/* 导出按钮 */
.go-export-btn {
  font-size: 26rpx;
  color: #1976D2;
  padding: 10rpx 24rpx;
  border: 1rpx solid #1976D2;
  border-radius: 6rpx;
}

.go-export-btn:active {
  background: #e3f2fd;
}

/* 对账单分享按钮 */
.share-bill-btn {
  font-size: 22rpx;
  color: #7B1FA2;
  border: 1rpx solid #7B1FA2;
  padding: 8rpx 18rpx;
  border-radius: 6rpx;
}

.share-bill-btn:active {
  background: #f3e5f5;
}

/* 隐藏 Canvas（用于后台绑图） */
.bill-canvas {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 750rpx;
  height: 1000rpx;
}

/* 功能面板 */
.tools-panel {
  padding: 16rpx 0;
}

.tool-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 8rpx;
  box-shadow: var(--shadow-card);
}

.tool-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tool-label {
  flex: 1;
  font-size: var(--text-base);
  color: var(--color-text);
}

.tool-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

/* 对账单独立行 */
.bill-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 12rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 14rpx;
  margin-top: 4rpx;
}

/* 后台底部 Tab 栏 */
.admin-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}
.admin-tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
}
.admin-tab-text {
  font-size: 28rpx;
  color: #666;
}
.admin-tab-item.active .admin-tab-text {
  color: #E8594B;
  font-weight: 500;
}

/* ===== 选择导出 ===== */
.export-entry-bar {
  padding: 0 0 16rpx;
}

.export-entry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #e3f2fd;
  border: 1rpx dashed #2196f3;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #1976D2;
}

.export-entry-btn:active {
  background: #bbdefb;
}

/* 选择栏 */
.select-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.select-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-bar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.select-count {
  font-size: 24rpx;
  color: #7F8C8D;
}

.select-cancel-btn {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 20rpx;
}

.select-export-btn {
  font-size: 26rpx;
  color: #fff;
  background: #1976D2;
  padding: 10rpx 24rpx;
  border-radius: 6rpx;
}

.select-export-btn:active {
  background: #1565C0;
}

/* 选择框 */
.select-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.select-checkbox.checked {
  background: #1976D2;
  border-color: #1976D2;
}

/* 订单选中高亮 */
.order-card.order-selected {
  border: 2rpx solid #1976D2;
  background: #f5f9ff;
}

.order-select-check {
  position: absolute;
  top: 20rpx;
  left: 16rpx;
  z-index: 2;
}
