.dashboard { padding: 16rpx; }
.date-tabs { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.date-tab {
  flex: 1; text-align: center; padding: 8rpx 0;
  background: #fff; border-radius: 8rpx; font-size: 28rpx;
  color: #7F8C8D;
}
.date-tab.active { background: #C0392B; color: #fff; }

/* Metrics cards */
.metrics { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.metric-card {
  width: calc(50% - 8rpx); padding: 16rpx;
  background: #fff; border-radius: 8rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.metric-value { font-size: 36rpx; font-weight: bold; color: #1A1A1A; }
.metric-label { font-size: 24rpx; color: #7F8C8D; margin-top: 4rpx; }
.metric-card.warning .metric-value { color: #E67E22; }
.metric-card.danger .metric-value { color: #C0392B; }

/* Trend chart */
.trend-section { background: #fff; border-radius: 8rpx; padding: 16rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.trend-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.trend-chart { display: flex; align-items: flex-end; gap: 8rpx; height: 200rpx; }
.trend-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; }
.trend-bar { width: 100%; max-width: 48rpx; background: #C0392B; border-radius: 6rpx 6rpx 0 0; min-height: 4rpx; }
.trend-label { font-size: 20rpx; color: #7F8C8D; margin-top: 4rpx; }
.trend-value { font-size: 20rpx; color: #1A1A1A; font-weight: 500; }

/* Rankings */
.rank-section { background: #fff; border-radius: 8rpx; padding: 16rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.rank-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.rank-item { display: flex; align-items: center; padding: 8rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.rank-item:last-child { border-bottom: none; }
.rank-num { width: 40rpx; font-size: 24rpx; font-weight: bold; color: #7F8C8D; flex-shrink: 0; }
.rank-num.top3 { color: #C0392B; }
.rank-info { flex: 1; overflow: hidden; }
.rank-name { font-size: 26rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.rank-sub { font-size: 22rpx; color: #7F8C8D; }
.rank-value { font-size: 26rpx; font-weight: 500; color: #1A1A1A; flex-shrink: 0; margin-left: 8rpx; }
.rank-bar-bg { height: 8rpx; background: #F0F0F0; border-radius: 4rpx; margin-top: 4rpx; }
.rank-bar-fill { height: 100%; background: #C0392B; border-radius: 4rpx; }

/* Shortage alerts */
.shortage-item { display: flex; align-items: center; padding: 8rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.shortage-status { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 6rpx; margin-right: 8rpx; flex-shrink: 0; }
.shortage-status.out { background: #FDEDEC; color: #C0392B; }
.shortage-status.low { background: #FEF5E7; color: #E67E22; }
.shortage-name { flex: 1; font-size: 26rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.shortage-days { font-size: 22rpx; color: #7F8C8D; flex-shrink: 0; }
