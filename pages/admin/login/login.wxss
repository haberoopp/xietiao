.login-container {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 120rpx;
}
.login-title { font-size: 36rpx; font-weight: 600; margin-bottom: 4rpx; }
.login-subtitle { font-size: 28rpx; color: #7F8C8D; margin-bottom: 48rpx; }
.login-card {
  width: 85%; padding: 32rpx; background: #fff;
  border-radius: 8rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.login-input {
  width: 100%; height: 88rpx;
  border: 2rpx solid #EEEEEE; border-radius: 8rpx;
  padding: 0 16rpx; font-size: 32rpx; box-sizing: border-box;
}
.login-input:focus { border-color: #C0392B; }
.login-btn {
  width: 100%; margin-top: 32rpx; background: #C0392B; color: #fff;
  border-radius: 8rpx; font-size: 32rpx;
  padding: 16rpx 0; text-align: center; border: none;
}
.login-btn:active { background: #A93226; opacity: 0.85; }
