.login-page {
  display: flex;
  flex-direction: column;
  padding-top: 100rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #d32f2f;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
}

.login-form {
  padding: 30rpx;
}

.login-btn {
  margin-top: 40rpx;
  width: 100%;
}

.demo-hint {
  margin-top: 40rpx;
  padding: 20rpx 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.demo-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.demo-row {
  font-size: 22rpx;
  color: #999;
  padding: 6rpx 0;
  font-family: monospace;
}

.demo-role {
  display: inline-block;
  background: #d32f2f;
  color: #fff;
  padding: 2rpx 10rpx;
  border-radius: 3rpx;
  font-size: 20rpx;
  margin-right: 6rpx;
}
