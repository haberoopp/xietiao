.section-title { font-size: 30rpx; font-weight: bold; padding: 16rpx 0 8rpx; }

.addr-section-card { padding: 8rpx 16rpx; }
.add-addr-row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #F0F0F0; margin-bottom: 16rpx; }
.add-addr-icon {
  width: 48rpx; height: 48rpx; line-height: 44rpx; text-align: center;
  font-size: 36rpx; color: var(--color-text-secondary);
  border: 2rpx solid #ccc; border-radius: 50%; margin-right: 16rpx; flex-shrink: 0;
}
.add-addr-text { flex: 1; font-size: 28rpx; color: var(--color-text-secondary); }
.add-addr-arrow { font-size: 40rpx; color: #ccc; flex-shrink: 0; }

.addr-compact { padding: 16rpx 0 16rpx; border-bottom: 1rpx solid #F0F0F0; margin-bottom: 16rpx; }
.addr-compact-line { font-size: 28rpx; color: #1A1A1A; font-weight: 500; }
.addr-compact-addr { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 4rpx; }

.address-picker {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx; margin-bottom: 16rpx;
  background: #FDF8E1; border: 2rpx dashed #E67E22; border-radius: 8rpx;
}
.picker-left { flex: 1; overflow: hidden; }
.picker-label { font-size: 26rpx; color: #E67E22; margin-bottom: 4rpx; }
.picker-preview { font-size: 28rpx; }
.preview-name { font-weight: 500; }
.preview-phone { color: var(--color-text-secondary); }
.picker-hint { font-size: 26rpx; color: var(--color-text-secondary); }
.picker-arrow { font-size: 40rpx; color: #ccc; flex-shrink: 0; margin-left: 16rpx; }

.save-addr-row { display: flex; align-items: center; padding: 16rpx 0 0; font-size: 26rpx; color: var(--color-text-secondary); }
.checkbox {
  width: 40rpx; height: 40rpx; border: 3rpx solid #ccc; border-radius: 50%;
  margin-right: 8rpx; box-sizing: border-box;
}
.checkbox.checked { background: var(--color-primary); border-color: var(--color-primary); }

.order-item {
  display: flex; align-items: center; padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0; position: relative;
}
.oi-del {
  position: absolute; top: 8rpx; right: 0;
  width: 56rpx; height: 56rpx; line-height: 54rpx; text-align: center;
  font-size: 24rpx; color: var(--color-text-secondary);
  border: 1rpx solid #DDD; border-radius: 50%; z-index: 1;
}
.order-item:last-child { border-bottom: none; }
.oi-image { width: 100rpx; height: 100rpx; border-radius: 8rpx; background: #E8E8E8; flex-shrink: 0; }
.oi-info { flex: 1; margin-left: 16rpx; overflow: hidden; }
.oi-name { font-size: 28rpx; }
.oi-meta { font-size: 24rpx; color: var(--color-text-secondary); margin-top: 4rpx; }
.oi-qty-ctrl { display: flex; align-items: center; gap: 8rpx; margin-top: 8rpx; }
.qty-btn {
  width: 88rpx; height: 88rpx; line-height: 88rpx;
  text-align: center; font-size: 28rpx; color: #1A1A1A;
  background: #F0F0F0; border-radius: 6rpx;
}
.qty-input { width: 80rpx; height: 48rpx; border: 1rpx solid #E0E0E0; border-radius: 6rpx; text-align: center; font-size: 26rpx; }
.oi-subtotal { font-size: 28rpx; color: #1A1A1A; flex-shrink: 0; }

.add-product-row {
  display: flex; align-items: center; justify-content: center;
  padding: 16rpx 0; margin-top: 8rpx;
  border: 2rpx dashed var(--color-primary); border-radius: 8rpx;
  font-size: 26rpx; color: var(--color-primary);
}
.add-product-row:active { background: var(--color-primary-light); }
.add-product-icon { font-size: 32rpx; margin-right: 8rpx; font-weight: bold; }

.total-line {
  display: flex; justify-content: flex-end; align-items: center;
  padding-top: 16rpx; font-size: 32rpx;
  border-top: 1rpx solid #F0F0F0; gap: 16rpx;
}

.delivery-card { padding: 8rpx 16rpx; }
.delivery-options { display: flex; gap: 16rpx; }
.delivery-option {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 0; border: 2rpx solid #EEEEEE; border-radius: 8rpx;
}
.delivery-option.active { border-color: var(--color-primary); background: var(--color-primary-light); }
.do-icon { font-size:44rpx;margin-bottom:8rpx;display:flex;align-items:center;justify-content:center; }
.delivery-option.active .do-icon { color: var(--color-primary); }
.do-label { font-size: 26rpx; color: #1A1A1A; }
.delivery-option.active .do-label { color: var(--color-primary); font-weight: 600; }

.logistics-warn {
  margin-top: 16rpx; padding: 8rpx 16rpx;
  background: #FFF3E0; border-radius: 8rpx;
  font-size: 24rpx; color: #E65100;
}
.pickup-hint {
  margin-top: 16rpx; padding: 8rpx 16rpx;
  background: #F0F7FF; border-radius: 8rpx;
  font-size: 24rpx; color: #1976D2;
}

.submit-btn { margin: 32rpx 0; width: 100%; }

.addr-search-box {
  padding: 16rpx 24rpx; background: #F5F6FA; border-radius: 8rpx;
  min-height: 50rpx; display: flex; align-items: center;
}
.addr-search-placeholder { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: var(--color-text-secondary); }
.addr-search-icon { font-size: 30rpx; }

.matched-customer { margin-top: 8rpx; display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; color: var(--color-primary); }
.matched-discount { background: var(--color-primary); color: #fff; padding: 2rpx 10rpx; border-radius: 6rpx; font-size: 22rpx; }

.original-price { text-decoration: line-through; color: var(--color-text-secondary); margin-right: 8rpx; }
.discount-note { font-size: 24rpx; color: var(--color-primary); background: var(--color-primary-light); padding: 4rpx 12rpx; border-radius: 6rpx; }
