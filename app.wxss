page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 20rpx;
  padding-bottom: 140rpx; /* 自定义tabBar高度 */
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  background-color: #d32f2f;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  border: none;
}

.btn-primary:active {
  background-color: #b71c1c;
}

.btn-outline {
  background-color: #fff;
  color: #d32f2f;
  border: 2rpx solid #d32f2f;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 16rpx 30rpx;
  text-align: center;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 表单 */
.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #d32f2f;
  background: #fff;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-state text {
  font-size: 28rpx;
}

/* 价格 */
.price {
  color: #d32f2f;
  font-weight: bold;
  font-size: 32rpx;
}

.price-symbol {
  font-size: 24rpx;
}

/* Badge */
.badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  line-height: 1;
  color: #fff;
  flex-shrink: 0;
  white-space: nowrap;
}

.badge-pending { background-color: #ff9800; }
.badge-processing { background-color: #2196f3; }
.badge-completed { background-color: #4caf50; }
.badge-cancelled { background-color: #9e9e9e; }
