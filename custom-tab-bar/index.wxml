<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="text"
    wx:for-index="idx"
    class="tab-item {{selected === idx ? 'active' : ''}}"
    data-index="{{idx}}"
    bindtap="switchTab"
  >
    <image class="tab-icon" src="/images/{{selected === idx ? item.selectedIconPath : item.iconPath}}" mode="aspectFit" />
    <view class="tab-text">{{item.text}}</view>
  </view>
  <view
    wx:if="{{showAdmin}}"
    class="tab-item {{selected === 3 ? 'active' : ''}}"
    data-index="3"
    bindtap="switchTab"
  >
    <image class="tab-icon" src="/images/{{selected === 3 ? adminTab.selectedIconPath : adminTab.iconPath}}" mode="aspectFit" />
    <view class="tab-text">后台</view>
  </view>
</view>
