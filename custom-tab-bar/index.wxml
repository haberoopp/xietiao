<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="text"
    wx:for-index="idx"
    class="tab-item {{selected === idx ? 'active' : ''}}"
    data-index="{{idx}}"
    bindtap="switchTab"
  >
    <view class="tab-icon-wrap">
      <text class="tab-icon-text {{selected === idx ? 'active' : ''}}">{{item.iconText}}</text>
      <view wx:if="{{item.badge > 0}}" class="tab-badge">{{item.badge > 99 ? '99+' : item.badge}}</view>
    </view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
